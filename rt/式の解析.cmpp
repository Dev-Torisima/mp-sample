関数 小数式の解析(テキスト 値) ： 小数
    //トークン化（扱いやすくする）
    //"2.4 + -8 * 92.1" なら  [ "2.4", "+", "-1", "*", "8", "*", "92.1" ] にします
    変数 トークン = テキスト配列_初期値
    整数 i
    整数 h
    ループ(要素数(値))
        もし(値[i] >= '0' & 値[i] <= '9' | 値[i] が '.')
            整数 j = 1
            ループ
                もし(!((値[i + j] >= '0' & 値[i + j] <= '9' | 値[i] が '.')))
                    抜ける
                おわり もし
                j += 1
            おわり ループ
            トークン = テキスト配列_要素の末尾追加(トークン, ClipArray(値, i, j))
            i += j - 1
            h += 1
        さらにもし(値[i] が '(' | 値[i] が ')')
            トークン = テキスト配列_要素の末尾追加(トークン, 文字をテキストにする(値[i]))
            h += 1
        さらにもし(値[i] が '+' | 値[i] が '-')
            テキスト ひとつ前 = TextArray_GetItem(トークン, h - 1)
            もし (ひとつ前 が "" | ひとつ前 が "(")
                もし (値[i] が '-')
                    トークン = テキスト配列_要素の末尾追加(トークン, "-1")
                    トークン = テキスト配列_要素の末尾追加(トークン, "*")
                    h += 2
                おわり もし
            ほか
                トークン = テキスト配列_要素の末尾追加(トークン, 文字をテキストにする(値[i]))
                h += 1
            おわり もし
        さらにもし(値[i] が '*' | 値[i] が '×')
            トークン = テキスト配列_要素の末尾追加(トークン, "*")
            h += 1
        さらにもし(値[i] が '/' | 値[i] が '÷')
            トークン = テキスト配列_要素の末尾追加(トークン, "/")
            h += 1
        おわり もし

        i += 1
    おわり ループ

    //構文の解析
    返す 小数式の解析_加減(トークン)
おわり 関数


//
//result = add
//add = mul ( ( "+" | "-" ) mul )*
//mul = unr ( ( "*" | "/" | "%" ) unr )*
//unr = ( "+" | "-" )? ( num | ( "(" add ")" ) )
//num = 0, 1, 2, 3, ...
//
