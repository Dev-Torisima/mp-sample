//This represents by using "char" type.
//ここでは「char」型で実装
func RemoveItem(char[] source, char target) : char[]
    char[] result = char[](len(source) - CountItem(source, target))
    num i
    num j

    loop(len(source))
        if (source[i] != target)
            result[j] = source[i]
            j += 1
        end if
        i += 1
    end loop

    return result
end func
