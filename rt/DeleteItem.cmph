//This represents by using "char" type.
//ここでは「char」型で実装
func DeleteItem(char[] array, num index) : char[]
    char[] result
    if (index < 0 | index >= len(array))
        result = array
    else 
        result = char[](len(array) - 1)
        num i
        num j
        loop(len(array))
            if (j != index)
                result[i] = array[j]
                i += 1
            end if

            j += 1
        end loop
    end if

    return result
end func
