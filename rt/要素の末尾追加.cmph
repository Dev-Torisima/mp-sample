

//This represents by using "char" type.
//ここでは「char」型で実装
func AdppendItem(char[] array, char value) : char[]
    var result = char[](len(array) + 1)
    num i = 0

    loop(len(array))
        result[i] = array[i]
        i += 1
    end loop

    result[i] = value

    return result
end func






//ここでは「char」型で実装
関数 要素の末尾追加(文字［］ 配列、 文字 対象) ： 文字［］
    変数 結果 = 文字［］(要素数(配列) + 1)
    整数 i = 0

    ループ (要素数(配列))
        結果[i] = 配列[i]
        i += 1
    おわり ループ

    結果[i] = 対象

    返す 結果
おわり 関数
