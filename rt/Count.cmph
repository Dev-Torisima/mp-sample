func CountChar(char[] source, char value) : num
    num c = 0
    num i = 0
    loop(len(source))
        if (source[i] == value)
            c += 1
        end if
        i += 1
    end loop
    return c
end func

func CountText(text source, text value) : num
    num c = 0
    num i = 0
    loop
        i = IndexOfText(source, value, i)
        if (i < 0)
            break
        end if
        c += 1
        i += len(value)
    end loop
    return c
end func
